{
	"schemaVersion": 1,
	"id": "cosmic-textures",
	"version": "${version}",
	"name": "Cosmic Textures",
	"description": "Custom textures for Cosmic Sky and Cosmic Prisons",
	"authors": [
		"Minecoin"
	],
	"license": "CC0-1.0",
	"icon": "assets/cosmic-textures/icon.png",
